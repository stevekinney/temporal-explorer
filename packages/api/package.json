{
  "name": "@temporal-explorer/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --entry-naming index.js",
    "clean": "rm -rf dist coverage",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "test": "bun test --timeout 30000",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporal-explorer/analyzer": "workspace:*",
    "@temporal-explorer/history": "workspace:*",
    "@temporal-explorer/mapper": "workspace:*",
    "@temporal-explorer/renderers": "workspace:*",
    "@temporal-explorer/schemas": "workspace:*"
  },
  "devDependencies": {
    "@repo/typescript-configuration": "workspace:*",
    "@types/bun": "^1.3.14",
    "oxlint": "^1.72.0"
  }
}
