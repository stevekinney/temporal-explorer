{
  "name": "@temporal-explorer/schemas",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./json-schema": "./src/json-schema.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist --entry-naming index.js",
    "clean": "rm -rf dist coverage",
    "lint": "oxlint --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "oxlint --fix --type-aware --tsconfig ./tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-configuration": "workspace:*",
    "@types/bun": "^1.3.14",
    "oxlint": "^1.72.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
