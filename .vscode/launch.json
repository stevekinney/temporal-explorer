{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Explore Fixtures (UI)",
      "type": "bun",
      "request": "launch",
      "program": "scripts/ui/explore-all-fixtures.ts",
      "cwd": "${workspaceFolder}",
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "name": "Debug Tests",
      "type": "bun",
      "request": "launch",
      "program": "test"
    },
    {
      "name": "Debug Current File",
      "type": "bun",
      "request": "launch",
      "program": "${file}",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
